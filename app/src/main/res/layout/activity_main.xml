<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:padding="24dp">

    <!-- App Title -->
    <TextView
        android:id="@+id/tvAppTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Adi"
        android:textColor="@color/primary"
        android:textSize="36sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your Personal AI Assistant"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/tvAppTitle"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="4dp" />

    <!-- Settings Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSettings"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:text="Settings"
        android:textAllCaps="false"
        android:textSize="14sp"
        android:textColor="@color/text_primary"
        app:backgroundTint="@color/card_dark"
        app:cornerRadius="20dp"
        app:icon="@android:drawable/ic_menu_manage"
        app:iconTint="@color/primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <!-- Siri-like Glow Background -->
    <View
        android:id="@+id/siriGlow"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:background="@drawable/siri_glow_circle"
        android:alpha="0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.35" />

    <!-- Siri Rotating Ring -->
    <View
        android:id="@+id/siriRing"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:background="@drawable/siri_gradient_ring"
        android:alpha="0"
        app:layout_constraintTop_toTopOf="@id/siriGlow"
        app:layout_constraintBottom_toBottomOf="@id/siriGlow"
        app:layout_constraintStart_toStartOf="@id/siriGlow"
        app:layout_constraintEnd_toEndOf="@id/siriGlow" />

    <!-- Pulse Outer Circle -->
    <View
        android:id="@+id/pulseOuter"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:background="@drawable/circle_pulse_outer"
        android:alpha="0.3"
        app:layout_constraintTop_toTopOf="@id/siriGlow"
        app:layout_constraintBottom_toBottomOf="@id/siriGlow"
        app:layout_constraintStart_toStartOf="@id/siriGlow"
        app:layout_constraintEnd_toEndOf="@id/siriGlow" />

    <!-- Pulse Inner Circle -->
    <View
        android:id="@+id/pulseInner"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:background="@drawable/circle_pulse_inner"
        android:alpha="0.5"
        app:layout_constraintTop_toTopOf="@id/pulseOuter"
        app:layout_constraintBottom_toBottomOf="@id/pulseOuter"
        app:layout_constraintStart_toStartOf="@id/pulseOuter"
        app:layout_constraintEnd_toEndOf="@id/pulseOuter" />

    <!-- Sound Wave Bars (5 bars like Siri's wave) -->
    <LinearLayout
        android:id="@+id/waveContainer"
        android:layout_width="160dp"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:alpha="0"
        app:layout_constraintTop_toTopOf="@id/pulseOuter"
        app:layout_constraintBottom_toBottomOf="@id/pulseOuter"
        app:layout_constraintStart_toStartOf="@id/pulseOuter"
        app:layout_constraintEnd_toEndOf="@id/pulseOuter">

        <View
            android:id="@+id/waveBar1"
            android:layout_width="6dp"
            android:layout_height="20dp"
            android:background="@drawable/siri_wave_bar"
            android:layout_marginEnd="6dp" />

        <View
            android:id="@+id/waveBar2"
            android:layout_width="6dp"
            android:layout_height="30dp"
            android:background="@drawable/siri_wave_bar"
            android:layout_marginEnd="6dp" />

        <View
            android:id="@+id/waveBar3"
            android:layout_width="6dp"
            android:layout_height="40dp"
            android:background="@drawable/siri_wave_bar"
            android:layout_marginEnd="6dp" />

        <View
            android:id="@+id/waveBar4"
            android:layout_width="6dp"
            android:layout_height="30dp"
            android:background="@drawable/siri_wave_bar"
            android:layout_marginEnd="6dp" />

        <View
            android:id="@+id/waveBar5"
            android:layout_width="6dp"
            android:layout_height="20dp"
            android:background="@drawable/siri_wave_bar" />
    </LinearLayout>

    <!-- Main Mic Button -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabMic"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@android:drawable/ic_btn_speak_now"
        android:contentDescription="Toggle Assistant"
        app:fabCustomSize="72dp"
        app:backgroundTint="@color/primary"
        app:tint="@color/white"
        app:layout_constraintTop_toTopOf="@id/pulseOuter"
        app:layout_constraintBottom_toBottomOf="@id/pulseOuter"
        app:layout_constraintStart_toStartOf="@id/pulseOuter"
        app:layout_constraintEnd_toEndOf="@id/pulseOuter" />

    <!-- State Label (Listening / Thinking / Speaking) -->
    <TextView
        android:id="@+id/tvStateLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/siri_blue"
        android:textSize="13sp"
        android:textStyle="italic"
        android:alpha="0"
        app:layout_constraintTop_toBottomOf="@id/pulseOuter"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <!-- Status Text -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/status_inactive"
        android:textColor="@color/text_secondary"
        android:textSize="16sp"
        android:textAlignment="center"
        app:layout_constraintTop_toBottomOf="@id/tvStateLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <!-- Conversation Log -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardConversation"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardBackgroundColor="@color/surface_dark"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvStatus"
        app:layout_constraintBottom_toTopOf="@id/layoutQuickActions"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp">

        <ScrollView
            android:id="@+id/scrollConversation"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp"
            android:fillViewport="true">

            <TextView
                android:id="@+id/tvConversation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp"
                android:text="Tap the mic to start talking to Adi..." />
        </ScrollView>
    </androidx.cardview.widget.CardView>

    <!-- Quick Actions -->
    <LinearLayout
        android:id="@+id/layoutQuickActions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp">

        <com.google.android.material.chip.Chip
            android:id="@+id/chipCall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Call"
            android:textColor="@color/text_primary"
            app:chipBackgroundColor="@color/card_dark"
            android:layout_marginEnd="8dp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Message"
            android:textColor="@color/text_primary"
            app:chipBackgroundColor="@color/card_dark"
            android:layout_marginEnd="8dp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipFlash"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Flash"
            android:textColor="@color/text_primary"
            app:chipBackgroundColor="@color/card_dark"
            android:layout_marginEnd="8dp" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chipAlarm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Alarm"
            android:textColor="@color/text_primary"
            app:chipBackgroundColor="@color/card_dark" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
